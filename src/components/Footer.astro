---
/**
 * Footer — four columns matching the grid's quarter-divisions (Layer 3.4 / 2.3):
 *   1. brand statement   2. services   3. company / contact
 *   4. trust-proof slot — RESERVED ON PURPOSE: present and visibly empty
 *      pre-launch rather than absent, so the first pilot-site mention has a
 *      home that's already decided (see 4.3). No placeholder testimonials.
 */
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SITE, TRACKS, TRACK_ORDER } from '../site.ts';
const year = new Date().getFullYear();
---

<footer class="footer panel-navy" id="contact">
  <div class="grid-container footer__grid">
    <!-- 1. brand statement -->
    <div class="footer__col footer__brand">
      <Logo background="dark" href={null} />
      <p class="footer__statement measure">
        Turning a continuous, noisy stream of data into a discrete, trustworthy,
        actionable finding.
      </p>
    </div>

    <!-- 2. services -->
    <nav class="footer__col" aria-label="Services">
      <h2 class="footer__heading">Services</h2>
      <ul class="footer__list">
        {TRACK_ORDER.map((id) => (
          <li><a class="footer__link" href={TRACKS[id].href}>{TRACKS[id].label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- 3. company / contact -->
    <div class="footer__col">
      <h2 class="footer__heading">Contact</h2>
      <ul class="footer__list">
        <li>
          <a class="footer__link footer__link--icon" href={`mailto:${SITE.email}`}>
            <Icon name="mail" size={16} stroke={1.75} /> {SITE.email}
          </a>
        </li>
        <li>
          <a class="footer__link footer__link--icon" href={`tel:${SITE.phone.replace(/[^+\d]/g, '')}`}>
            <Icon name="phone" size={16} stroke={1.75} /> {SITE.phone}
          </a>
        </li>
      </ul>
    </div>

    <!-- 4. trust-proof slot — reserved, visibly empty pre-launch (4.3) -->
    <div class="footer__col footer__trust">
      <h2 class="footer__heading">Proven on site</h2>
      <p class="footer__reserved">
        Pilot results are added here as they’re verified.
      </p>
    </div>
  </div>

  <div class="grid-container footer__base">
    <div class="col footer__baseinner">
      <span>&copy; {year} {SITE.name}</span>
      <span class="footer__capability">Capabilities offered; volume claims made only where verified.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-top: var(--space-9);
    margin-top: var(--space-9);
  }
  .footer__grid {
    row-gap: var(--space-7);
    padding-bottom: var(--space-8);
  }
  .footer__col { grid-column: span 3; }
  .footer__brand { grid-column: span 3; }

  .footer__statement {
    margin-top: var(--space-4);
    color: var(--color-on-navy-dim);
    font-size: var(--fs-small);
    line-height: 1.6;
    max-width: 32ch;
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-amber); /* bright amber on navy (2.1) */
    margin-bottom: var(--space-4);
  }
  .footer__list { list-style: none; padding: 0; display: grid; gap: var(--space-3); }
  .footer__link {
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    font-size: var(--fs-cta);
    transition: color var(--dur-press) var(--ease-resolve);
  }
  .footer__link:hover { color: #fff; }
  .footer__link--icon { display: inline-flex; align-items: center; gap: var(--space-2); }

  /* the reserved slot reads intentional, not broken */
  .footer__trust {
    border: 1px dashed var(--color-on-navy-line);
    border-radius: var(--radius);
    padding: var(--space-5);
  }
  .footer__reserved {
    color: var(--color-on-navy-dim);
    font-size: var(--fs-small);
    line-height: 1.55;
  }

  .footer__base {
    border-top: 1px solid var(--color-on-navy-line);
    padding-block: var(--space-5) var(--space-6);
  }
  .footer__baseinner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    color: var(--color-on-navy-dim);
    font-size: var(--fs-small);
  }

  @media (max-width: 880px) {
    .footer__col,
    .footer__brand { grid-column: 1 / 5; }
  }
</style>
