---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import { SITE } from '../site.ts';

const contactHref = `mailto:${SITE.email}`;
---

<Base
  title="Imaging QC & Compliance"
  description="Medical physics and quality assurance services supporting commissioning, compliance testing, quality control and education."
  navVariant="service"
  activeTrack="imaging"
>
  <section class="service-simple">
    <div class="grid-container">
      <div class="col service-simple__inner" style="--from:3;--to:11" data-reveal>
        <h1>Imaging QC &amp; Compliance</h1>
        <p>
          Medical physics and quality assurance services supporting commissioning,
          compliance testing, quality control and education.
        </p>
        <Button href={contactHref} variant="primary">Contact Beacon Diagnostics</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .service-simple {
    min-height: calc(100vh - 76px);
    display: grid;
    align-items: center;
    padding-block: clamp(5rem, 10vw, 9rem);
    background:
      radial-gradient(circle at 50% 10%, rgba(181, 212, 244, 0.32), transparent 30rem),
      linear-gradient(180deg, #f8fbfd 0%, #eef5fb 100%);
  }
  .service-simple__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .service-simple h1 {
    max-width: 13ch;
  }
  .service-simple p {
    max-width: 62ch;
    margin-top: var(--space-6);
    margin-bottom: var(--space-7);
    color: var(--color-slate);
    font-size: var(--fs-lead);
    line-height: 1.55;
  }

  @media (max-width: 880px) {
    .service-simple__inner {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
