---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import { TRACKS } from '../site.ts';
---

<Base
  title="Beacon Diagnostics"
  description="Beacon Diagnostics - clear insight. Better outcomes."
  navVariant="gateway"
>
  <section class="home-hero">
    <div class="grid-container">
      <div class="col home-hero__inner" style="--from:2;--to:12" data-reveal>
        <Logo href={null} size={116} class="home-hero__logo" />
        <h1>Beacon Diagnostics</h1>
        <p class="home-hero__sub">Clear insight. Better outcomes.</p>
        <div class="home-hero__actions" aria-label="Service areas">
          <a class="home-hero__button" href={TRACKS.imaging.href}>Imaging QC &amp; Compliance</a>
          <a class="home-hero__button" href={TRACKS.cardiac.href}>Cardiac Services</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .home-hero {
    min-height: calc(100vh - 76px);
    display: grid;
    align-items: center;
    padding-block: clamp(5rem, 10vw, 10rem);
    background:
      radial-gradient(circle at 50% 18%, rgba(181, 212, 244, 0.42), transparent 30rem),
      linear-gradient(180deg, #eef5fb 0%, #f8fbfd 100%);
  }
  .home-hero__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .home-hero__logo {
    margin-bottom: var(--space-7);
    transform: scale(1.2);
    transform-origin: center;
  }
  .home-hero h1 {
    font-family: var(--font-body);
    font-size: clamp(2.8rem, 6vw, 6rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-navy);
  }
  .home-hero__sub {
    margin-top: var(--space-5);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--color-slate);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .home-hero__button {
    min-width: min(100%, 260px);
    padding: 1rem 1.35rem;
    border: 1px solid rgba(11, 36, 71, 0.18);
    border-radius: var(--radius-sm);
    background: #fff;
    color: var(--color-navy);
    box-shadow: 0 14px 34px rgba(11, 36, 71, 0.08);
    text-decoration: none;
    font-size: var(--fs-cta);
    font-weight: var(--weight-medium);
    transition: transform var(--dur-press) var(--ease-resolve),
      border-color var(--dur-press) var(--ease-resolve),
      box-shadow var(--dur-press) var(--ease-resolve);
  }
  .home-hero__button:hover {
    transform: translateY(-2px);
    border-color: rgba(156, 111, 14, 0.45);
    box-shadow: 0 18px 42px rgba(11, 36, 71, 0.12);
  }

  @media (max-width: 640px) {
    .home-hero { min-height: auto; }
    .home-hero__logo { transform: scale(1); }
    .home-hero h1 { letter-spacing: 0.04em; }
    .home-hero__sub { letter-spacing: 0.04em; }
    .home-hero__actions { width: 100%; }
    .home-hero__button { width: 100%; }
  }
</style>
