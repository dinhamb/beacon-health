---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import { SITE } from '../site.ts';

const contactHref = `mailto:${SITE.email}`;
const services = [
  'CIED support',
  'Remote monitoring',
  'Rhythm analysis (Holter, ECG and event monitoring)',
];
---

<Base
  title="Cardiac Services"
  description="CIED support, remote monitoring, and rhythm analysis services led by Braden Dinham, Cardiac Physiologist."
  navVariant="service"
  activeTrack="cardiac"
>
  <section class="cardiac-simple">
    <div class="grid-container">
      <div class="col cardiac-simple__header" style="--from:2;--to:12" data-reveal>
        <h1>Cardiac Services</h1>
      </div>
    </div>

    <div class="grid-container cardiac-simple__grid">
      <section class="col cardiac-simple__section" style="--from:2;--to:7" data-reveal>
        <h2>What We Offer</h2>
        <ul>
          {services.map((service) => <li>{service}</li>)}
        </ul>
      </section>

      <section class="col cardiac-simple__section" style="--from:7;--to:12" data-reveal>
        <h2>Clinical Leadership</h2>
        <p>Lead by Braden Dinham, Cardiac Physiologist.</p>
        <p>
          Braden serves on the Board of Directors and co-chairs the CDRMS
          examination committee for the International Board of Heart Rhythm
          Examiners.
        </p>
      </section>
    </div>

    <div class="grid-container">
      <div class="col cardiac-simple__cta" style="--from:2;--to:12" data-reveal>
        <Button href={contactHref} variant="primary">Contact Beacon Diagnostics</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .cardiac-simple {
    min-height: calc(100vh - 76px);
    padding-block: clamp(5rem, 10vw, 9rem);
    background:
      radial-gradient(circle at 50% 8%, rgba(181, 212, 244, 0.32), transparent 30rem),
      linear-gradient(180deg, #f8fbfd 0%, #eef5fb 100%);
  }
  .cardiac-simple__header {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .cardiac-simple__grid {
    row-gap: var(--space-6);
  }
  .cardiac-simple__section {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(11, 36, 71, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    box-shadow: 0 14px 34px rgba(11, 36, 71, 0.07);
  }
  .cardiac-simple__section h2 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-5);
  }
  .cardiac-simple__section ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    color: var(--color-slate);
    font-size: var(--fs-lead);
    line-height: 1.45;
  }
  .cardiac-simple__section li {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(11, 36, 71, 0.08);
  }
  .cardiac-simple__section li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }
  .cardiac-simple__section p {
    color: var(--color-slate);
    font-size: var(--fs-lead);
    line-height: 1.55;
  }
  .cardiac-simple__section p + p {
    margin-top: var(--space-4);
  }
  .cardiac-simple__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-8);
  }

  @media (max-width: 880px) {
    .cardiac-simple__header {
      text-align: left;
    }
    .cardiac-simple__section {
      padding: var(--space-6);
    }
    .cardiac-simple__cta {
      justify-content: flex-start;
    }
  }
</style>
